<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pembayaran — AEROSTREET</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Mono:wght@400;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#111110;
    --panel:#1B1A17;
    --panel-2:#221F1B;
    --bone:#F1EDE3;
    --bone-dim:#C9C4B6;
    --red:#E8402C;
    --teal:#3AABA0;
    --concrete:#8C8A80;
    --line: rgba(241,237,227,0.14);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    background:var(--ink);
    color:var(--bone);
    font-family:'Manrope', sans-serif;
  }
  .display{ font-family:'Anton', sans-serif; text-transform:uppercase; letter-spacing:0.01em; }
  .mono{ font-family:'Space Mono', monospace; }
  a{ color:inherit; text-decoration:none; }

  header{
    position:sticky; top:0; z-index:150;
    display:flex; justify-content:space-between; align-items:center;
    padding:20px 5vw;
    background:rgba(17,17,16,0.9);
    backdrop-filter: blur(10px);
    border-bottom:1px solid var(--line);
  }
  .logo{ display:flex; align-items:center; gap:10px; font-size:22px; letter-spacing:0.02em; }
  .logo .mark{ width:30px; height:30px; }
  .step-nav{
    display:flex; align-items:center; gap:10px;
    font-family:'Space Mono', monospace; font-size:11px; letter-spacing:0.1em;
    color:var(--concrete); text-transform:uppercase;
  }
  .step-nav .active{ color:var(--red); }
  .step-nav span.sep{ opacity:0.4; }

  .page-hero{
    padding:50px 5vw 30px;
    border-bottom:1px solid var(--line);
  }
  .page-hero .eyebrow{
    font-family:'Space Mono', monospace; font-size:11px; letter-spacing:0.2em;
    color:var(--teal); text-transform:uppercase; margin-bottom:14px; display:block;
  }
  .page-hero h1{ font-size:clamp(38px, 6vw, 60px); line-height:0.95; }

  .checkout-wrap{
    display:grid;
    grid-template-columns: 1.4fr 1fr;
    gap:40px;
    padding:40px 5vw 100px;
    max-width:1400px;
    margin:0 auto;
  }
  @media (max-width:900px){ .checkout-wrap{ grid-template-columns:1fr; } }

  /* ===== PAYMENT METHODS ===== */
  .section-title{
    font-family:'Space Mono', monospace; font-size:12px; letter-spacing:0.14em;
    text-transform:uppercase; color:var(--bone-dim); margin-bottom:18px;
    display:flex; align-items:center; gap:10px;
  }
  .section-title::before{
    content:""; width:20px; height:1px; background:var(--red);
  }

  .method-tabs{
    display:grid; grid-template-columns:repeat(3,1fr); gap:10px;
    margin-bottom:24px;
  }
  .method-tab{
    background:var(--panel); border:1px solid var(--line);
    padding:16px 12px; cursor:pointer; text-align:center;
    transition: all 0.25s ease;
  }
  .method-tab:hover{ border-color:rgba(241,237,227,0.3); }
  .method-tab.active{
    border-color:var(--red); background:rgba(232,64,44,0.08);
  }
  .method-tab .icon{ font-size:22px; margin-bottom:8px; display:block; }
  .method-tab .label{
    font-family:'Space Mono', monospace; font-size:10.5px; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--bone-dim);
  }
  .method-tab.active .label{ color:var(--bone); }

  .method-panel{
    background:var(--panel); border:1px solid var(--line);
    padding:28px; display:none;
  }
  .method-panel.show{ display:block; }

  /* Bank transfer */
  .bank-option{
    display:flex; justify-content:space-between; align-items:center;
    padding:16px 0; border-bottom:1px dashed var(--line);
    cursor:pointer;
  }
  .bank-option:last-child{ border-bottom:none; }
  .bank-option .bname{ font-weight:700; font-size:15px; }
  .bank-option .bnote{ font-size:12px; color:var(--concrete); margin-top:2px; }
  .radio-dot{
    width:16px; height:16px; border-radius:50%; border:1px solid var(--concrete);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .bank-option.selected .radio-dot{ border-color:var(--red); }
  .radio-dot .fill{
    width:8px; height:8px; border-radius:50%; background:var(--red);
    opacity:0; transition:opacity 0.2s;
  }
  .bank-option.selected .radio-dot .fill{ opacity:1; }

  .va-box{
    margin-top:20px; padding:18px; background:var(--panel-2);
    border:1px dashed var(--line);
    display:none;
  }
  .va-box.show{ display:block; }
  .va-box .va-label{
    font-family:'Space Mono', monospace; font-size:10px; letter-spacing:0.1em;
    color:var(--teal); text-transform:uppercase; margin-bottom:8px;
  }
  .va-row{ display:flex; justify-content:space-between; align-items:center; gap:10px; }
  .va-number{ font-family:'Space Mono', monospace; font-size:20px; letter-spacing:0.05em; }
  .copy-btn{
    font-family:'Space Mono', monospace; font-size:10.5px; letter-spacing:0.08em;
    text-transform:uppercase; background:transparent; border:1px solid var(--bone);
    color:var(--bone); padding:8px 14px; cursor:pointer; transition:all 0.2s;
    white-space:nowrap;
  }
  .copy-btn:hover{ background:var(--bone); color:var(--ink); }
  .copy-btn.copied{ background:var(--teal); border-color:var(--teal); color:var(--ink); }

  /* E-wallet */
  .ewallet-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }
  .ewallet-item{
    display:flex; align-items:center; gap:12px;
    padding:14px 16px; border:1px solid var(--line); cursor:pointer;
    transition:all 0.2s;
  }
  .ewallet-item:hover{ border-color:rgba(241,237,227,0.3); }
  .ewallet-item.selected{ border-color:var(--red); background:rgba(232,64,44,0.08); }
  .ewallet-item .ew-icon{
    width:34px; height:34px; border-radius:8px; background:var(--panel-2);
    display:flex; align-items:center; justify-content:center; font-size:16px;
    flex-shrink:0;
  }
  .ewallet-item .ew-name{ font-weight:600; font-size:14px; }

  /* QRIS */
  .qris-wrap{ text-align:center; }
  .qris-card{
    display:inline-block; background:var(--bone); padding:20px;
    border-radius:6px;
  }
  .qris-card canvas{ display:block; }
  .qris-brand{
    margin-top:14px; display:flex; align-items:center; justify-content:center; gap:8px;
  }
  .qris-brand .dot{ width:6px; height:6px; border-radius:50%; background:var(--red); }
  .qris-brand span{
    font-family:'Space Mono', monospace; font-size:11px; letter-spacing:0.15em;
    text-transform:uppercase; color:var(--bone-dim);
  }
  .qris-timer{
    margin-top:18px; font-family:'Space Mono', monospace; font-size:13px;
    color:var(--teal); letter-spacing:0.05em;
  }
  .qris-steps{
    text-align:left; margin-top:24px; padding-top:20px; border-top:1px dashed var(--line);
  }
  .qris-steps li{
    list-style:none; display:flex; gap:12px; margin-bottom:12px;
    font-size:13.5px; color:var(--bone-dim); font-weight:300;
  }
  .qris-steps .num{
    width:20px; height:20px; border:1px solid var(--teal); color:var(--teal);
    border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-family:'Space Mono', monospace; font-size:10px; flex-shrink:0;
  }
  .qris-actions{ margin-top:20px; display:flex; gap:10px; justify-content:center; }

  /* ===== SUMMARY ===== */
  .summary-card{
    background:var(--panel); border:1px solid var(--line);
    padding:28px; height:fit-content; position:sticky; top:100px;
  }
  .summary-item{
    display:flex; justify-content:space-between; gap:14px;
    padding:14px 0; border-bottom:1px dashed var(--line);
    font-size:13.5px;
  }
  .summary-item .si-name{ font-weight:600; }
  .summary-item .si-meta{ color:var(--concrete); font-size:12px; margin-top:3px; }
  .summary-item .si-price{ font-family:'Space Mono', monospace; white-space:nowrap; }

  .summary-totals{ margin-top:16px; }
  .total-row{
    display:flex; justify-content:space-between; padding:8px 0;
    font-size:13px; color:var(--bone-dim);
  }
  .total-row.grand{
    border-top:1px solid var(--line); margin-top:8px; padding-top:16px;
    color:var(--bone); font-size:16px; font-weight:700;
  }
  .total-row.grand .amount{ font-family:'Space Mono', monospace; color:var(--red); }

  .pay-btn{
    width:100%; margin-top:24px; padding:16px;
    background:var(--red); border:none; color:var(--bone);
    font-family:'Space Mono', monospace; font-size:12px; letter-spacing:0.1em;
    text-transform:uppercase; cursor:pointer; transition:all 0.25s ease;
  }
  .pay-btn:hover{ background:#c9351f; }

  .secure-note{
    margin-top:16px; display:flex; align-items:center; gap:8px;
    font-size:11.5px; color:var(--concrete); justify-content:center;
  }

  footer{
    text-align:center; padding:26px 5vw; font-family:'Space Mono', monospace;
    font-size:10px; letter-spacing:0.08em; color:var(--concrete);
    border-top:1px solid var(--line);
  }
</style>
</head>
<body>

<header>
  <a href="index.html" class="logo">
    <svg width="30" height="30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 8 L88 88 L68 88 L50 50 L32 88 L12 88 Z" fill="#F1EDE3"/>
      <path d="M50 40 L64 88 L54 88 L50 68 L46 88 L36 88 Z" fill="#E8402C"/>
    </svg>
    <span class="display">AEROSTREET</span>
  </a>
  <div class="step-nav">
    <span>Keranjang</span><span class="sep">→</span>
    <span>Pengiriman</span><span class="sep">→</span>
    <span class="active">Pembayaran</span>
  </div>
</header>

<section class="page-hero">
  <span class="eyebrow mono">Langkah 3 dari 3</span>
  <h1 class="display">Pilih Metode<br>Pembayaran.</h1>
</section>

<div class="checkout-wrap">

  <!-- LEFT: PAYMENT METHODS -->
  <div>
    <div class="section-title">Metode Pembayaran</div>

    <div class="method-tabs">
      <div class="method-tab active" data-method="bank">
        <span class="icon">🏦</span>
        <span class="label">Transfer Bank</span>
      </div>
      <div class="method-tab" data-method="ewallet">
        <span class="icon">📱</span>
        <span class="label">E-Wallet</span>
      </div>
      <div class="method-tab" data-method="qris">
        <span class="icon">▦</span>
        <span class="label">QRIS</span>
      </div>
    </div>

    <!-- BANK TRANSFER PANEL -->
    <div class="method-panel show" id="panel-bank">
      <div class="bank-option selected" data-bank="BCA" data-va="8808 1234 5678 901">
        <div>
          <div class="bname">Bank BCA</div>
          <div class="bnote">Virtual Account — proses otomatis</div>
        </div>
        <div class="radio-dot"><div class="fill"></div></div>
      </div>
      <div class="bank-option" data-bank="Mandiri" data-va="8908 8812 3456 78">
        <div>
          <div class="bname">Bank Mandiri</div>
          <div class="bnote">Virtual Account — proses otomatis</div>
        </div>
        <div class="radio-dot"><div class="fill"></div></div>
      </div>
      <div class="bank-option" data-bank="BNI" data-va="8828 9912 3400 55">
        <div>
          <div class="bname">Bank BNI</div>
          <div class="bnote">Virtual Account — proses otomatis</div>
        </div>
        <div class="radio-dot"><div class="fill"></div></div>
      </div>
      <div class="bank-option" data-bank="BRI" data-va="8890 1122 3344 09">
        <div>
          <div class="bname">Bank BRI</div>
          <div class="bnote">Virtual Account — proses otomatis</div>
        </div>
        <div class="radio-dot"><div class="fill"></div></div>
      </div>

      <div class="va-box show" id="vaBox">
        <div class="va-label">Nomor Virtual Account — <span id="vaBankName">BCA</span></div>
        <div class="va-row">
          <div class="va-number" id="vaNumber">8808 1234 5678 901</div>
          <button class="copy-btn" id="copyVa">Salin</button>
        </div>
      </div>
    </div>

    <!-- E-WALLET PANEL -->
    <div class="method-panel" id="panel-ewallet">
      <div class="ewallet-grid">
        <div class="ewallet-item selected" data-wallet="GoPay">
          <div class="ew-icon">🟢</div>
          <div class="ew-name">GoPay</div>
        </div>
        <div class="ewallet-item" data-wallet="OVO">
          <div class="ew-icon">🟣</div>
          <div class="ew-name">OVO</div>
        </div>
        <div class="ewallet-item" data-wallet="DANA">
          <div class="ew-icon">🔵</div>
          <div class="ew-name">DANA</div>
        </div>
        <div class="ewallet-item" data-wallet="ShopeePay">
          <div class="ew-icon">🟠</div>
          <div class="ew-name">ShopeePay</div>
        </div>
      </div>
      <div class="va-box show" style="margin-top:24px;">
        <div class="va-label">Nomor Handphone Terdaftar</div>
        <div class="va-row">
          <input type="tel" placeholder="0812-xxxx-xxxx" class="mono" style="background:transparent;border:none;color:var(--bone);font-size:16px;width:100%;outline:none;">
        </div>
      </div>
    </div>

    <!-- QRIS PANEL -->
    <div class="method-panel" id="panel-qris">
      <div class="qris-wrap">
        <div class="qris-card">
          <canvas id="qrCanvas" width="220" height="220"></canvas>
        </div>
        <div class="qris-brand">
          <div class="dot"></div>
          <span>QRIS — Scan &amp; Bayar</span>
        </div>
        <div class="qris-timer">Selesaikan dalam <span id="qrTimer">14:59</span></div>

        <ol class="qris-steps">
          <li><span class="num">1</span> Buka aplikasi e-wallet atau m-banking favoritmu.</li>
          <li><span class="num">2</span> Pilih menu <b>Scan QR / QRIS</b>.</li>
          <li><span class="num">3</span> Arahkan kamera ke kode QR di atas, lalu konfirmasi nominal.</li>
          <li><span class="num">4</span> Selesaikan pembayaran — status akan otomatis terupdate.</li>
        </ol>

        <div class="qris-actions">
          <button class="copy-btn" id="downloadQr">Unduh QR</button>
          <button class="copy-btn" id="refreshQr">Muat Ulang</button>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: ORDER SUMMARY -->
  <div>
    <div class="summary-card">
      <div class="section-title">Ringkasan Pesanan</div>

      <div class="summary-item">
        <div>
          <div class="si-name">Tokyo Hitam Jet</div>
          <div class="si-meta">Low-Top Sneaker · 1x</div>
        </div>
        <div class="si-price">Rp 259.000</div>
      </div>
      <div class="summary-item">
        <div>
          <div class="si-name">Hoops High Coral</div>
          <div class="si-meta">High-Top Sneaker · 1x</div>
        </div>
        <div class="si-price">Rp 299.000</div>
      </div>

      <div class="summary-totals">
        <div class="total-row"><span>Subtotal</span><span class="mono">Rp 558.000</span></div>
        <div class="total-row"><span>Pengiriman</span><span class="mono">Rp 20.000</span></div>
        <div class="total-row"><span>Biaya Layanan</span><span class="mono">Rp 2.500</span></div>
        <div class="total-row grand"><span>Total Bayar</span><span class="amount">Rp 580.500</span></div>
      </div>

      <button class="pay-btn" id="payBtn">Bayar Sekarang</button>
      <div class="secure-note mono">🔒 Transaksi Terenkripsi &amp; Aman</div>
    </div>
  </div>

</div>

<footer class="mono">© 2026 AEROSTREET — SEMUA HAK DILINDUNGI</footer>

<script>
  // ===== Tab switching =====
  const tabs = document.querySelectorAll(".method-tab");
  const panels = document.querySelectorAll(".method-panel");
  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      tabs.forEach(t => t.classList.remove("active"));
      panels.forEach(p => p.classList.remove("show"));
      tab.classList.add("active");
      document.getElementById("panel-" + tab.dataset.method).classList.add("show");
      if (tab.dataset.method === "qris") drawQR();
    });
  });

  // ===== Bank selection =====
  document.querySelectorAll(".bank-option").forEach(opt => {
    opt.addEventListener("click", () => {
      document.querySelectorAll(".bank-option").forEach(o => o.classList.remove("selected"));
      opt.classList.add("selected");
      document.getElementById("vaBankName").textContent = opt.dataset.bank;
      document.getElementById("vaNumber").textContent = opt.dataset.va;
    });
  });

  // ===== E-wallet selection =====
  document.querySelectorAll(".ewallet-item").forEach(item => {
    item.addEventListener("click", () => {
      document.querySelectorAll(".ewallet-item").forEach(i => i.classList.remove("selected"));
      item.classList.add("selected");
    });
  });

  // ===== Copy VA number =====
  document.getElementById("copyVa").addEventListener("click", function(){
    const num = document.getElementById("vaNumber").textContent.replace(/\s/g, "");
    navigator.clipboard.writeText(num).then(() => {
      this.textContent = "Tersalin!";
      this.classList.add("copied");
      setTimeout(() => { this.textContent = "Salin"; this.classList.remove("copied"); }, 1800);
    });
  });

  // ===== QR CODE GENERATOR (visual mockup, seeded pseudo-random module pattern) =====
  function seededRandom(seed){
    let s = seed;
    return () => { s = (s * 9301 + 49297) % 233280; return s / 233280; };
  }

  function drawQR(){
    const canvas = document.getElementById("qrCanvas");
    const ctx = canvas.getContext("2d");
    const size = 220;
    const grid = 25; // modules per side
    const cell = size / grid;
    const rand = seededRandom(Date.now() % 100000);

    ctx.clearRect(0, 0, size, size);
    ctx.fillStyle = "#F1EDE3";
    ctx.fillRect(0, 0, size, size);
    ctx.fillStyle = "#111110";

    // Build module map
    const modules = Array.from({length: grid}, () => Array(grid).fill(0));

    // Random data modules
    for (let y = 0; y < grid; y++) {
      for (let x = 0; x < grid; x++) {
        modules[y][x] = rand() > 0.55 ? 1 : 0;
      }
    }

    // Finder patterns (corner squares) — top-left, top-right, bottom-left
    function drawFinder(ox, oy){
      for (let y = 0; y < 7; y++) {
        for (let x = 0; x < 7; x++) {
          const border = (x === 0 || x === 6 || y === 0 || y === 6);
          const innerFill = (x >= 2 && x <= 4 && y >= 2 && y <= 4);
          modules[oy+y][ox+x] = (border || innerFill) ? 1 : 0;
        }
      }
    }
    drawFinder(0, 0);
    drawFinder(grid - 7, 0);
    drawFinder(0, grid - 7);

    // Clear quiet zone around finders slightly for realism
    for (let y = 0; y < 8; y++) {
      for (let x = 0; x < 8; x++) {
        if (x === 7 || y === 7) modules[y][x] = 0;
        if (x === grid-8 || y === 7) modules[y][grid-1-x] = 0;
        if (x === 7 || y === grid-8) modules[grid-1-y][x] = 0;
      }
    }

    // Draw modules
    for (let y = 0; y < grid; y++) {
      for (let x = 0; x < grid; x++) {
        if (modules[y][x]) {
          ctx.fillRect(x * cell, y * cell, cell - 0.6, cell - 0.6);
        }
      }
    }
  }

  drawQR();

  document.getElementById("refreshQr").addEventListener("click", drawQR);

  document.getElementById("downloadQr").addEventListener("click", () => {
    const canvas = document.getElementById("qrCanvas");
    const link = document.createElement("a");
    link.download = "qris-aerostreet.png";
    link.href = canvas.toDataURL("image/png");
    link.click();
  });

  // ===== Countdown timer =====
  let seconds = 15 * 60 - 1;
  const timerEl = document.getElementById("qrTimer");
  setInterval(() => {
    if (seconds <= 0) return;
    seconds--;
    const m = String(Math.floor(seconds / 60)).padStart(2, "0");
    const s = String(seconds % 60).padStart(2, "0");
    timerEl.textContent = `${m}:${s}`;
  }, 1000);

  // ===== Pay button (demo confirmation) =====
  document.getElementById("payBtn").addEventListener("click", () => {
    const activeMethod = document.querySelector(".method-tab.active .label").textContent.trim();
    alert(`Menyelesaikan pembayaran via ${activeMethod}...\n(Ini adalah tampilan demo, belum terhubung ke payment gateway sungguhan.)`);
  });
</script>

</body>
</html>
